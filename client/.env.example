# URL of the backend API server (Express + Better Auth)
# On Railway: set this to your API service public URL, e.g. https://api.xxx.up.railway.app
# IMPORTANT: This is baked into the client bundle at build time — changing it requires a rebuild.
VITE_API_URL=http://localhost:3000

# Sentry — browser error monitoring (optional)
# Set both variables to activate. VITE_SENTRY_ENVIRONMENT controls which env is tagged in Sentry.
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# VITE_SENTRY_ENVIRONMENT=development
