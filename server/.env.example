# PostgreSQL connection string
# For Neon: postgresql://USER:PASSWORD@ep-xxx.region.neon.tech/hakkoryu?sslmode=require
DATABASE_URL="postgresql://postgres:hakkoryu@localhost:5432/hakkoryu?schema=public"

# Better Auth — generate with: openssl rand -base64 32
# Must be at least 32 characters. Do NOT use this placeholder in production.
BETTER_AUTH_SECRET="REPLACE_THIS_WITH_OUTPUT_OF_openssl_rand_-base64_32"
BETTER_AUTH_URL="http://localhost:3000"

# Seed — admin credentials (only needed when running: bun run db:seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_AT_LEAST_12_CHARS"

# Allowed origins for CORS and Better Auth (comma-separated)
# This is the single source of truth — used by both CORS middleware and Better Auth trustedOrigins
TRUSTED_ORIGINS="http://localhost:5173"
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_actual_cloud_name"
CLOUDINARY_API_KEY="your_actual_api_key"
CLOUDINARY_API_SECRET="your_actual_api_secret"
