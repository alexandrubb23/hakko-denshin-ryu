# PostgreSQL connection string
# For Neon: postgresql://USER:PASSWORD@ep-xxx.region.neon.tech/hakkoryu?sslmode=require
DATABASE_URL="postgresql://postgres:hakkoryu@localhost:5432/hakkoryu?schema=public"

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Seed — admin credentials
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password1234"

# Trusted origins for CORS (comma-separated)
TRUSTED_ORIGINS="http://localhost:5173"
