# Test environment — used automatically by Bun when NODE_ENV=test
# These are non-production credentials. Safe to commit.

# Separate test database — must be created manually before running tests:
#   createdb hakkoryu_test   (or via your Postgres client)
DATABASE_URL="postgresql://postgres:hakkoryu@localhost:5432/hakkoryu_test?schema=public"

# Test-only secret — do NOT reuse in any other environment
BETTER_AUTH_SECRET="playwright-e2e-test-secret-do-not-use-in-production"

# Points to the test API port (set by Playwright, but documented here for clarity)
BETTER_AUTH_URL="http://localhost:3001"

# Client base URL — used for building invitation email links
CLIENT_URL="http://localhost:5174"

# Allow requests from the test client port
TRUSTED_ORIGINS="http://localhost:5174"

# Admin credentials used by the seed script during test setup
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_EMAIL="admin@test.com"
SEED_ADMIN_PASSWORD="admin-test-password-123"

# Cloudinary — real credentials not needed in test mode.
# uploadAvatar() short-circuits when NODE_ENV=test and returns a fake URL,
# so the DB is still updated but no real API call is made.
# These placeholder values satisfy env validation (z.string().min(1)).
CLOUDINARY_CLOUD_NAME="test"
CLOUDINARY_API_KEY="test"
CLOUDINARY_API_SECRET="test"

# Resend — placeholder satisfies env validation; emails are not sent in test mode.
RESEND_API_KEY="re_test_placeholder"
RESEND_FROM_EMAIL="noreply@senshinkan.ro"
